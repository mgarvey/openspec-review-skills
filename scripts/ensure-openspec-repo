#!/usr/bin/env bash
set -euo pipefail

managed_marker="Managed by mgarvey/openspec-review-skills"
mode="check"
mode_set=0
force=0

usage() {
  cat <<'EOF'
Usage: ensure-openspec-repo [--check|--apply|--print-plan] [--force]

Install or repair the standard OpenSpec/Codex repo setup from the local
mgarvey/openspec-review-skills checkout.

Modes:
  --check       Report drift without modifying files. This is the default.
  --apply       Modify the current Git repo, then run validation.
  --print-plan  Print the actions that would be taken without modifying files.

Options:
  --force       Allow running outside ~/Code. This does not force-overwrite
                unknown files.
  -h, --help    Show this help.

The command must be run from inside the downstream Git repository. It installs
real files under .agents/skills, initializes OpenSpec when openspec/ is missing,
installs scripts/validate-openspec-review-skills.sh, and writes managed
.agents/skills/README.md, .agents/skills/UPSTREAM.md, and
.agents/docs/read-only-discovery.md.

It never uses .codex/skills, Git submodules, startup hooks, or symlinked
.agents/skills entries.
EOF
}

die() {
  echo "error: $*" >&2
  exit 1
}

warn() {
  echo "warning: $*" >&2
}

set_mode() {
  if [ "$mode_set" -ne 0 ]; then
    die "choose only one mode"
  fi
  mode="$1"
  mode_set=1
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --check)
      set_mode "check"
      ;;
    --apply)
      set_mode "apply"
      ;;
    --print-plan)
      set_mode "print-plan"
      ;;
    --force)
      force=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown option: $1"
      ;;
  esac
  shift
done

resolve_script_path() {
  local path="$1"
  local dir target
  while [ -L "$path" ]; do
    dir="$(cd "$(dirname "$path")" && pwd -P)"
    target="$(readlink "$path")"
    case "$target" in
      /*)
        path="$target"
        ;;
      *)
        path="$dir/$target"
        ;;
    esac
  done
  printf '%s/%s\n' "$(cd "$(dirname "$path")" && pwd -P)" "$(basename "$path")"
}

script_path="$(resolve_script_path "${BASH_SOURCE[0]}")"
script_dir="$(cd "$(dirname "$script_path")" && pwd -P)"
source_repo="$(cd "$script_dir/.." && pwd -P)"
source_skills="$source_repo/skills"
source_manifest="$source_repo/skills-manifest.json"
source_installer="$source_repo/scripts/install-skills.sh"
source_validator="$source_repo/templates/downstream-copy-workflow/scripts/validate-openspec-review-skills.sh"
source_support_doc="$source_repo/docs/read-only-discovery.md"

[ -d "$source_skills" ] || die "missing source skills directory: $source_skills"
[ -f "$source_manifest" ] || die "missing source manifest: $source_manifest"
[ -x "$source_installer" ] || die "missing executable installer: $source_installer"
[ -f "$source_validator" ] || die "missing downstream validator template: $source_validator"
[ -f "$source_support_doc" ] || die "missing support document: $source_support_doc"
command -v python3 >/dev/null 2>&1 || die "python3 is required"

target_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
[ -n "$target_root" ] || die "run this command from inside a Git worktree"
target_root="$(cd "$target_root" && pwd -P)"

if [ "$target_root" = "$source_repo" ]; then
  die "refusing to bootstrap the openspec-review-skills source repository itself"
fi

home_dir="${HOME:-}"
[ -n "$home_dir" ] || die "HOME is not set"
if [ -d "$home_dir/Code" ]; then
  code_root="$(cd "$home_dir/Code" && pwd -P)"
else
  code_root="$home_dir/Code"
fi

case "$target_root" in
  "$code_root"|"$code_root"/*)
    ;;
  *)
    if [ "$force" -ne 1 ]; then
      die "refusing to run outside ~/Code without --force: $target_root"
    fi
    ;;
esac

skills_dir="$target_root/.agents/skills"
validator_path="$target_root/scripts/validate-openspec-review-skills.sh"
legacy_vendor="$target_root/.agents/vendor/openspec-review-skills"
gitmodules_path="$target_root/.gitmodules"
openspec_dir="$target_root/openspec"
readme_path="$skills_dir/README.md"
upstream_path="$skills_dir/UPSTREAM.md"
support_doc_path="$target_root/.agents/docs/read-only-discovery.md"
source_commit="$(git -C "$source_repo" rev-parse HEAD 2>/dev/null || true)"
source_tag="$(git -C "$source_repo" describe --tags --exact-match 2>/dev/null || true)"
source_status="$(git -C "$source_repo" status --porcelain --untracked-files=all 2>/dev/null || true)"
source_tree_state="clean"
if [ -n "$source_status" ]; then
  source_tree_state="dirty; local source checkout has uncommitted changes"
fi
source_url="https://github.com/mgarvey/openspec-review-skills"

managed_names=()
while IFS= read -r name; do
  [ -n "$name" ] || continue
  managed_names+=("$name")
done < <(python3 - "$source_manifest" <<'PY'
import json
import sys
from pathlib import Path

data = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
if data.get("package") != "mgarvey/openspec-review-skills":
    raise SystemExit("source manifest package mismatch")
for skill in data.get("skills", []):
    name = skill.get("name")
    if isinstance(name, str) and name:
        print(name)
PY
)

[ "${#managed_names[@]}" -gt 0 ] || die "no managed skills found in $source_manifest"

actions=()
conflicts=()
legacy_symlink_count=0

add_action() {
  actions+=("$1")
}

add_conflict() {
  conflicts+=("$1")
}

path_exists() {
  [ -e "$1" ] || [ -L "$1" ]
}

rel_path() {
  local path="$1"
  case "$path" in
    "$target_root"/*)
      printf '%s\n' "${path#"$target_root"/}"
      ;;
    "$target_root")
      printf '.\n'
      ;;
    *)
      printf '%s\n' "$path"
      ;;
  esac
}

desired_readme() {
  cat <<EOF
# Managed OpenSpec Review Skills

<!-- $managed_marker: ensure-openspec-repo README -->

The skill directories in this folder are committed vendored files from
\`mgarvey/openspec-review-skills\`. They are real files, not Git submodules and
not symlinks, so fresh clones and new Git worktrees can discover them without
extra setup.

Do not edit managed skill files locally. Update
\`mgarvey/openspec-review-skills\`, then refresh this repo with:

\`\`\`bash
ensure-openspec-repo --apply
\`\`\`

Validate the local wiring with:

\`\`\`bash
bash scripts/validate-openspec-review-skills.sh
\`\`\`

Do not add duplicate managed copies under \`.codex/skills\`.
EOF
}

desired_upstream() {
  cat <<EOF
# OpenSpec Review Skills Upstream

<!-- $managed_marker: ensure-openspec-repo upstream metadata -->

- Package: mgarvey/openspec-review-skills
- Source repository: $source_url
- Source commit: ${source_commit:-unknown}
- Source exact tag: ${source_tag:-not exactly on a tag}
- Source tree state: $source_tree_state
- Target: .agents/skills
- Refresh command: ensure-openspec-repo --apply

This repo should use vendored real files only. Do not use Git submodules,
symlinks, .codex/skills duplicates, or startup/bootstrap hooks for these managed
skills.
EOF
}

desired_support_doc() {
  python3 - "$source_support_doc" "$managed_marker" <<'PY'
import sys
from pathlib import Path

source = Path(sys.argv[1])
managed_marker = sys.argv[2]
lines = source.read_text(encoding="utf-8").splitlines()
if not lines:
    raise SystemExit("support document is empty")

print(lines[0])
print()
print(f"<!-- {managed_marker}: read-only discovery support doc -->")
rest = lines[1:]
while rest and not rest[0].strip():
    rest = rest[1:]
if rest:
    print()
    print("\n".join(rest))
PY
}

write_if_needed() {
  local path="$1"
  local content="$2"
  local description="$3"
  local dir
  dir="$(dirname "$path")"
  if [ "$mode" = "apply" ]; then
    mkdir -p "$dir"
    printf '%s\n' "$content" > "$path"
  fi
  add_action "$description"
}

file_matches_text() {
  local path="$1"
  local content="$2"
  [ -f "$path" ] || return 1
  local tmp
  tmp="$(mktemp)"
  printf '%s\n' "$content" > "$tmp"
  if cmp -s "$path" "$tmp"; then
    rm -f "$tmp"
    return 0
  fi
  rm -f "$tmp"
  return 1
}

managed_text_file() {
  local path="$1"
  [ -f "$path" ] && grep -Fq "$managed_marker" "$path"
}

legacy_managed_readme_file() {
  local path="$1"
  [ -f "$path" ] || return 1
  python3 - "$path" <<'PY'
import re
import sys
from pathlib import Path

path = Path(sys.argv[1])
text = path.read_text(encoding="utf-8")
lower = text.lower()
normalized = re.sub(r"\s+", " ", lower)
lines = [line.strip() for line in text.splitlines() if line.strip()]

has_vendored_file_model = (
    "real vendored files" in normalized
    or (
        "vendored files" in normalized
        and ("real" in normalized or "copied" in normalized or "committed" in normalized)
    )
    or ("committed files" in normalized and ("vendored" in normalized or "copied" in normalized))
)
fresh_checkout_note = bool(
    re.search(r"fresh[- ](clones?|checkouts?|worktrees?)|new (git )?worktrees?", normalized)
)
setup_without_submodule_note = (
    fresh_checkout_note
    or "submodule initialization" in normalized
    or "submodule init" in normalized
    or "git submodule update" in normalized
)
too_large = len(text) > 5000
project_specific = any(
    signal in lower
    for signal in [
        "local project",
        "project-specific",
        "customer",
        "sku",
    ]
)

checks = [
    bool(lines and lines[0] == "# Managed OpenSpec Review Skills"),
    "mgarvey/openspec-review-skills" in text,
    ".agents/skills" in text,
    has_vendored_file_model,
    setup_without_submodule_note,
    "submodule" in lower,
    "symlink" in lower,
    "startup" in lower or "bootstrap" in lower or "hook" in lower,
]

raise SystemExit(0 if all(checks) and not too_large and not project_specific else 1)
PY
}

legacy_managed_upstream_file() {
  local path="$1"
  [ -f "$path" ] || return 1
  python3 - "$path" <<'PY'
import re
import sys
from pathlib import Path

path = Path(sys.argv[1])
text = path.read_text(encoding="utf-8")
lower = text.lower()
lines = [line.strip() for line in text.splitlines() if line.strip()]

too_large = len(text) > 5000
project_specific = any(
    signal in lower
    for signal in [
        "local project",
        "project-specific",
        "customer",
        "sku",
    ]
)

has_legacy_warning_set = (
    ".agents/vendor/openspec-review-skills" in text
    and "submodule" in lower
    and ".codex/skills" in text
    and "symlink" in lower
    and ("startup" in lower or "bootstrap" in lower or "hook" in lower)
)
has_support_doc_metadata = (
    "upstream commit" in lower
    and ("copy date" in lower or "copied" in lower)
    and ".agents/skills" in text
    and ".agents/docs/read-only-discovery.md" in text
    and "../../docs/read-only-discovery.md" in text
)

checks = [
    bool(lines and lines[0] == "# OpenSpec Review Skills Upstream"),
    "mgarvey/openspec-review-skills" in text,
    bool(re.search(r"\bv[0-9]+\.[0-9]+\.[0-9]+\b", text)),
    "refresh" in lower and "openspec review skills" in lower,
    has_legacy_warning_set or has_support_doc_metadata,
]

raise SystemExit(0 if all(checks) and not too_large and not project_specific else 1)
PY
}

legacy_managed_support_doc_file() {
  local path="$1"
  [ -f "$path" ] || return 1
  python3 - "$path" <<'PY'
import sys
from pathlib import Path

path = Path(sys.argv[1])
text = path.read_text(encoding="utf-8")
lower = text.lower()
lines = [line.strip() for line in text.splitlines() if line.strip()]

checks = [
    bool(lines and lines[0] == "# Read-only Discovery"),
    "repository-provided wrappers" in lower,
    "local instructions" in lower,
    "git status --short" in text,
    "git diff" in text,
    "AGENTS.md" in text,
    "destructive commands" in lower,
    "review" in lower,
]

project_specific = any(
    signal in lower
    for signal in [
        "local project",
        "project-specific",
        "customer",
        "sku",
    ]
)
too_large = len(text) > 10000

raise SystemExit(0 if all(checks) and not too_large and not project_specific else 1)
PY
}

legacy_managed_text_file() {
  local path="$1"
  if [ "$path" = "$readme_path" ]; then
    legacy_managed_readme_file "$path"
    return
  fi
  if [ "$path" = "$upstream_path" ]; then
    legacy_managed_upstream_file "$path"
    return
  fi
  if [ "$path" = "$support_doc_path" ]; then
    legacy_managed_support_doc_file "$path"
    return
  fi
  return 1
}

legacy_managed_validator_file() {
  local path="$1"
  [ -f "$path" ] || return 1
  python3 - "$path" <<'PY'
import re
import sys
from pathlib import Path

path = Path(sys.argv[1])
text = path.read_text(encoding="utf-8")
lower = text.lower()

v012_validator_phrases = [
    ".agents/vendor/openspec-review-skills exists; vendored rollout must not use a Git submodule",
    ".gitmodules references openspec-review-skills; remove the submodule and vendor real skill files instead",
    "is a symlink; .agents/skills entries must be committed real files",
    "missing .agents/skills/.openspec-review-skills-manifest.json; refresh vendored skills with install-skills.sh --codex-current",
    "managed OpenSpec review skills must not be duplicated in .codex/skills",
]
legacy_validator_phrases = [
    "OpenSpec review skills must use real vendored files, not .agents/vendor/openspec-review-skills",
    "OpenSpec review skills must not use git submodules",
    "OpenSpec review skills under .agents/skills must not be symlinks",
    "OpenSpec review skills must not be duplicated in .codex/skills",
]
support_doc_validator_phrases = [
    ".agents/vendor/openspec-review-skills",
    ".gitmodules",
    ".agents/skills/.openspec-review-skills-manifest.json",
    ".agents/skills/UPSTREAM.md",
    ".agents/docs/read-only-discovery.md",
    "symlink",
]

project_specific_signals = [
    "local project",
    "project-specific",
    "mysql",
    "customer",
    "sku",
]

too_large = len(text) > 20000
project_specific = any(signal in lower for signal in project_specific_signals)
looks_like_shell = bool(re.search(r"^#!.*\b(bash|sh)\b", text, re.MULTILINE))
has_package_reference = (
    "mgarvey/openspec-review-skills" in text
    or ".agents/vendor/openspec-review-skills" in text
)
has_success_message = (
    "OpenSpec review skills validation passed" in text
    or ("openspec review skills" in lower and "validation" in lower)
)
has_manifest_reference = ".openspec-review-skills-manifest.json" in text
has_known_legacy_phrases = (
    all(phrase in text for phrase in v012_validator_phrases)
    or all(phrase in text for phrase in legacy_validator_phrases)
    or all(phrase in text for phrase in support_doc_validator_phrases)
)

raise SystemExit(
    0
    if (
        looks_like_shell
        and has_package_reference
        and has_success_message
        and has_manifest_reference
        and has_known_legacy_phrases
        and not too_large
        and not project_specific
    )
    else 1
)
PY
}

validator_is_managed() {
  local path="$1"
  [ -f "$path" ] || return 1
  grep -Fq "$managed_marker" "$path"
}

gitmodules_declares_legacy_vendor() {
  [ -f "$gitmodules_path" ] || return 1
  python3 - "$gitmodules_path" <<'PY'
import sys
from pathlib import Path

path = Path(sys.argv[1])
lines = path.read_text(encoding="utf-8").splitlines(keepends=True)
section = []


def is_section(line: str) -> bool:
    return line.lstrip().startswith("[") and line.rstrip().endswith("]")


def section_matches(block) -> bool:
    if not block or not block[0].lstrip().startswith("[submodule "):
        return False
    text = "".join(block)
    has_path = False
    for line in block:
        key, sep, value = line.strip().partition("=")
        if sep and key.strip() == "path" and value.strip() == ".agents/vendor/openspec-review-skills":
            has_path = True
            break
    return has_path and "openspec-review-skills" in text


for line in lines:
    if is_section(line):
        if section_matches(section):
            raise SystemExit(0)
        section = [line]
    else:
        section.append(line)

raise SystemExit(0 if section_matches(section) else 1)
PY
}

dir_is_empty() {
  local path="$1"
  [ -d "$path" ] && [ -z "$(find "$path" -mindepth 1 -maxdepth 1 -print -quit)" ]
}

vendor_manifest_matches_package() {
  local path="$1"
  [ -f "$path/skills-manifest.json" ] || return 1
  python3 - "$path/skills-manifest.json" <<'PY' >/dev/null 2>&1
import json
import sys
from pathlib import Path
data = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
raise SystemExit(0 if data.get("package") == "mgarvey/openspec-review-skills" else 1)
PY
}

vendor_is_git_checkout() {
  local path="$1"
  local top
  top="$(git -C "$path" rev-parse --show-toplevel 2>/dev/null || true)"
  [ -n "$top" ] || return 1
  top="$(cd "$top" && pwd -P)"
  [ "$top" = "$(cd "$path" && pwd -P)" ]
}

vendor_git_remote_matches() {
  local path="$1"
  vendor_is_git_checkout "$path" || return 1
  git -C "$path" remote get-url origin 2>/dev/null | grep -Fq "openspec-review-skills"
}

vendor_git_tree_is_clean() {
  local path="$1"
  [ -z "$(git -C "$path" status --porcelain --untracked-files=all --ignored 2>/dev/null)" ]
}

vendor_is_metadata_only() {
  local path="$1"
  vendor_manifest_matches_package "$path" || return 1
  [ -z "$(find "$path" -mindepth 1 -maxdepth 1 ! -name skills-manifest.json -print -quit)" ]
}

vendor_is_known_legacy() {
  local path="$1"
  if [ -L "$path" ]; then
    return 0
  fi
  [ -d "$path" ] || return 1
  if dir_is_empty "$path" && gitmodules_declares_legacy_vendor; then
    return 0
  fi
  if vendor_git_remote_matches "$path"; then
    return 0
  fi
  if vendor_manifest_matches_package "$path"; then
    return 0
  fi
  return 1
}

vendor_safe_to_remove() {
  local path="$1"
  if [ -L "$path" ]; then
    return 0
  fi
  if dir_is_empty "$path"; then
    return 0
  fi
  if vendor_git_remote_matches "$path"; then
    vendor_git_tree_is_clean "$path"
    return
  fi
  vendor_is_metadata_only "$path"
}

skill_tree_matches_source() {
  local source_path="$1"
  local target_path="$2"
  [ -d "$source_path" ] || return 1
  [ -d "$target_path" ] || return 1
  [ ! -L "$target_path" ] || return 1
  python3 - "$source_path" "$target_path" <<'PY'
import hashlib
import os
import sys
from pathlib import Path

def digest(root: Path) -> str:
    h = hashlib.sha256()
    for current, dirs, files in os.walk(root):
        dirs.sort()
        files.sort()
        current_path = Path(current)
        for dirname in list(dirs):
            path = current_path / dirname
            rel = path.relative_to(root).as_posix()
            if path.is_symlink():
                h.update(b"L\0")
                h.update(rel.encode())
                h.update(b"\0")
                h.update(os.readlink(path).encode())
                h.update(b"\0")
                dirs.remove(dirname)
        for filename in files:
            path = current_path / filename
            rel = path.relative_to(root).as_posix()
            if path.is_symlink():
                h.update(b"L\0")
                h.update(rel.encode())
                h.update(b"\0")
                h.update(os.readlink(path).encode())
                h.update(b"\0")
            else:
                h.update(b"F\0")
                h.update(rel.encode())
                h.update(b"\0")
                h.update(path.read_bytes())
                h.update(b"\0")
    return h.hexdigest()

raise SystemExit(0 if digest(Path(sys.argv[1])) == digest(Path(sys.argv[2])) else 1)
PY
}

skill_tree_matches_manifest_checksum() {
  local target_path="$1"
  local manifest_path="$2"
  local name="$3"
  [ -d "$target_path" ] || return 1
  [ ! -L "$target_path" ] || return 1
  [ -f "$manifest_path" ] || return 1
  python3 - "$target_path" "$manifest_path" "$name" <<'PY'
import hashlib
import json
import os
import sys
from pathlib import Path

root = Path(sys.argv[1])
manifest = Path(sys.argv[2])
name = sys.argv[3]

data = json.loads(manifest.read_text(encoding="utf-8"))
if data.get("package") != "mgarvey/openspec-review-skills":
    raise SystemExit(1)

expected = None
for skill in data.get("skills", []):
    if isinstance(skill, dict) and skill.get("name") == name:
        checksum = skill.get("checksum")
        if isinstance(checksum, str) and checksum:
            expected = checksum
        break
if not expected:
    raise SystemExit(1)

h = hashlib.sha256()
for current, dirs, files in os.walk(root):
    dirs.sort()
    files.sort()
    current_path = Path(current)
    for dirname in list(dirs):
        path = current_path / dirname
        rel = path.relative_to(root).as_posix()
        if path.is_symlink():
            h.update(b"L\0")
            h.update(rel.encode())
            h.update(b"\0")
            h.update(os.readlink(path).encode())
            h.update(b"\0")
            dirs.remove(dirname)
    for filename in files:
        path = current_path / filename
        rel = path.relative_to(root).as_posix()
        if path.is_symlink():
            h.update(b"L\0")
            h.update(rel.encode())
            h.update(b"\0")
            h.update(os.readlink(path).encode())
            h.update(b"\0")
        else:
            h.update(b"F\0")
            h.update(rel.encode())
            h.update(b"\0")
            h.update(path.read_bytes())
            h.update(b"\0")

raise SystemExit(0 if h.hexdigest() == expected else 1)
PY
}

remove_legacy_gitmodules_sections() {
  [ -f "$gitmodules_path" ] || return 0
  python3 - "$gitmodules_path" "$mode" <<'PY'
import sys
from pathlib import Path

path = Path(sys.argv[1])
mode = sys.argv[2]
lines = path.read_text(encoding="utf-8").splitlines(keepends=True)
out = []
section = []
removed = False

def is_section(line: str) -> bool:
    return line.lstrip().startswith("[") and line.rstrip().endswith("]")

def flush(block):
    global removed
    text = "".join(block)
    has_path = False
    for line in block:
        key, sep, value = line.strip().partition("=")
        if sep and key.strip() == "path" and value.strip() == ".agents/vendor/openspec-review-skills":
            has_path = True
            break
    if block and block[0].lstrip().startswith("[submodule ") and has_path and "openspec-review-skills" in text:
        removed = True
        return
    out.extend(block)

for line in lines:
    if is_section(line):
        flush(section)
        section = [line]
    else:
        section.append(line)
flush(section)

if removed and mode == "apply":
    path.write_text("".join(out), encoding="utf-8")
print("removed" if removed else "unchanged")
PY
}

plan_legacy_symlinks() {
  local name link target expected_target
  for name in "${managed_names[@]}"; do
    link="$skills_dir/$name"
    if [ -L "$link" ]; then
      target="$(readlink "$link")"
      expected_target="../vendor/openspec-review-skills/skills/$name"
      if [ "$target" = "$expected_target" ]; then
        legacy_symlink_count=$((legacy_symlink_count + 1))
        if [ "$mode" = "apply" ]; then
          rm -f "$link"
        fi
        add_action "remove legacy managed symlink $(rel_path "$link")"
      else
        add_conflict "$(rel_path "$link") is a symlink, but not a known managed OpenSpec review skill symlink"
      fi
    fi
  done
}

plan_legacy_codex_duplicates() {
  local name legacy source_path legacy_manifest
  legacy_manifest="$target_root/.codex/skills/.openspec-review-skills-manifest.json"
  for name in "${managed_names[@]}"; do
    legacy="$target_root/.codex/skills/$name"
    source_path="$source_skills/$name"
    if path_exists "$legacy"; then
      if skill_tree_matches_source "$source_path" "$legacy" \
        || skill_tree_matches_manifest_checksum "$legacy" "$legacy_manifest" "$name"; then
        if [ "$mode" = "apply" ]; then
          rm -rf "$legacy"
        fi
        add_action "remove managed duplicate $(rel_path "$legacy")"
      else
        add_conflict "$(rel_path "$legacy") exists but does not match the managed source copy or its recorded managed checksum; remove or back it up manually"
      fi
    fi
  done
}

plan_legacy_codex_manifest() {
  local legacy_manifest="$target_root/.codex/skills/.openspec-review-skills-manifest.json"
  [ -f "$legacy_manifest" ] || return 0
  if python3 - "$legacy_manifest" <<'PY' >/dev/null 2>&1
import json
import sys
from pathlib import Path
data = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
raise SystemExit(0 if data.get("package") == "mgarvey/openspec-review-skills" else 1)
PY
  then
    if [ "$mode" = "apply" ]; then
      rm -f "$legacy_manifest"
    fi
    add_action "remove managed legacy .codex/skills install manifest"
  else
    add_conflict "$(rel_path "$legacy_manifest") exists but is not a managed OpenSpec review skills manifest"
  fi
}

plan_empty_legacy_codex_dirs() {
  local skills_legacy="$target_root/.codex/skills"
  local codex_legacy="$target_root/.codex"
  if [ -d "$skills_legacy" ] && [ -z "$(find "$skills_legacy" -mindepth 1 -maxdepth 1 -print -quit)" ]; then
    if [ "$mode" = "apply" ]; then
      rmdir "$skills_legacy"
    fi
    add_action "remove empty legacy .codex/skills directory"
  fi
  if [ -d "$codex_legacy" ] && [ -z "$(find "$codex_legacy" -mindepth 1 -maxdepth 1 -print -quit)" ]; then
    if [ "$mode" = "apply" ]; then
      rmdir "$codex_legacy"
    fi
    add_action "remove empty legacy .codex directory"
  fi
}

plan_managed_text_file() {
  local path="$1"
  local content="$2"
  local label="$3"
  local legacy_label="$4"
  if file_matches_text "$path" "$content"; then
    return
  fi
  if path_exists "$path"; then
    if [ -L "$path" ]; then
      add_conflict "$(rel_path "$path") is a symlink; managed OpenSpec review skills metadata/support files must be real files"
      return
    fi
    if managed_text_file "$path"; then
      write_if_needed "$path" "$content" "$label"
      return
    fi
    if legacy_managed_text_file "$path"; then
      write_if_needed "$path" "$content" "$legacy_label"
      return
    fi
    add_conflict "$(rel_path "$path") exists and is not marked as managed or recognized as legacy managed OpenSpec review skills metadata/support content; refusing to overwrite"
    return
  fi
  write_if_needed "$path" "$content" "$label"
}

plan_validator() {
  if [ -f "$validator_path" ] && cmp -s "$source_validator" "$validator_path"; then
    return
  fi
  if path_exists "$validator_path"; then
    if validator_is_managed "$validator_path"; then
      if [ "$mode" = "apply" ]; then
        mkdir -p "$(dirname "$validator_path")"
        cp "$source_validator" "$validator_path"
        chmod +x "$validator_path"
      fi
      add_action "install or update $(rel_path "$validator_path")"
      return
    fi
    if legacy_managed_validator_file "$validator_path"; then
      if [ "$mode" = "apply" ]; then
        mkdir -p "$(dirname "$validator_path")"
        cp "$source_validator" "$validator_path"
        chmod +x "$validator_path"
      fi
      add_action "replace legacy managed $(rel_path "$validator_path")"
      return
    fi
    add_conflict "$(rel_path "$validator_path") exists and does not look like the managed or legacy managed OpenSpec validator"
    return
  fi
  if [ "$mode" = "apply" ]; then
    mkdir -p "$(dirname "$validator_path")"
    cp "$source_validator" "$validator_path"
    chmod +x "$validator_path"
  fi
  add_action "install or update $(rel_path "$validator_path")"
}

plan_gitmodules_cleanup() {
  if [ -f "$gitmodules_path" ] && grep -Fq "openspec-review-skills" "$gitmodules_path"; then
    result="$(remove_legacy_gitmodules_sections)"
    if [ "$result" = "removed" ]; then
      add_action "remove openspec-review-skills submodule section from .gitmodules"
    else
      add_conflict ".gitmodules references openspec-review-skills outside a recognizable submodule section"
    fi
  fi
}

plan_vendor_cleanup() {
  if path_exists "$legacy_vendor"; then
    if vendor_is_known_legacy "$legacy_vendor"; then
      if ! vendor_safe_to_remove "$legacy_vendor"; then
        add_conflict "$(rel_path "$legacy_vendor") contains local or untracked content; remove or back it up manually"
        return
      fi
      if [ "$mode" = "apply" ]; then
        rm -rf "$legacy_vendor"
      fi
      add_action "remove legacy $(rel_path "$legacy_vendor")"
    else
      add_conflict "$(rel_path "$legacy_vendor") exists but is not recognizable as the managed legacy vendor checkout"
    fi
  fi
}

plan_openspec_init() {
  if [ ! -d "$openspec_dir" ]; then
    if [ "$mode" = "apply" ]; then
      command -v openspec >/dev/null 2>&1 || die "openspec is required to initialize this repo"
      (
        cd "$target_root"
        openspec init --tools codex
      )
    fi
    add_action "initialize OpenSpec with openspec init --tools codex"
  fi
}

run_installer() {
  if [ "$mode" = "apply" ]; then
    (
      cd "$target_root"
      OPEN_SPEC_REVIEW_INSTALL_SUPPORT_DOC=0 "$source_installer" --codex-current
    )
    add_action "install/update real managed skill files under .agents/skills"
  else
    installer_output="$(
      cd "$target_root"
      OPEN_SPEC_REVIEW_INSTALL_SUPPORT_DOC=0 "$source_installer" --dry-run --codex-current 2>&1
    )" || {
      if [ "$legacy_symlink_count" -gt 0 ] && printf '%s\n' "$installer_output" | grep -Fq "symlink collision"; then
        add_action "install/update real managed skill files under .agents/skills"
        return
      fi
      printf '%s\n' "$installer_output" >&2
      add_conflict "skill installer dry-run failed"
      return
    }
    if printf '%s\n' "$installer_output" | grep -Eq '^(install|backup|prune) '; then
      add_action "install/update real managed skill files under .agents/skills"
    fi
  fi
}

run_validation() {
  (
    cd "$target_root"
    bash scripts/validate-openspec-review-skills.sh
  )
}

if [ "$mode" = "apply" ] && [ "${ENSURE_OPENSPEC_REPO_PREFLIGHT:-0}" != "1" ]; then
  preflight_args=(--print-plan)
  if [ "$force" -eq 1 ]; then
    preflight_args+=(--force)
  fi
  ENSURE_OPENSPEC_REPO_PREFLIGHT=1 "$script_path" "${preflight_args[@]}" >/dev/null
fi

if [ "$mode" = "apply" ] && [ ! -d "$openspec_dir" ]; then
  command -v openspec >/dev/null 2>&1 || die "openspec is required to initialize this repo"
fi

plan_vendor_cleanup
plan_gitmodules_cleanup
plan_legacy_symlinks
plan_legacy_codex_duplicates
plan_legacy_codex_manifest
plan_empty_legacy_codex_dirs
plan_openspec_init
run_installer
plan_validator
plan_managed_text_file "$readme_path" "$(desired_readme)" "write managed .agents/skills/README.md" "replace legacy managed .agents/skills/README.md"
plan_managed_text_file "$upstream_path" "$(desired_upstream)" "write managed .agents/skills/UPSTREAM.md" "replace legacy managed .agents/skills/UPSTREAM.md"
plan_managed_text_file "$support_doc_path" "$(desired_support_doc)" "write managed .agents/docs/read-only-discovery.md" "replace legacy managed .agents/docs/read-only-discovery.md"

if [ "${#conflicts[@]}" -gt 0 ]; then
  echo "OpenSpec repo bootstrap conflicts:"
  for conflict in "${conflicts[@]}"; do
    echo "  - $conflict"
  done
  exit 1
fi

case "$mode" in
  print-plan)
    echo "OpenSpec repo bootstrap plan for $target_root:"
    if [ "${#actions[@]}" -eq 0 ]; then
      echo "  - no changes needed"
    else
      for action in "${actions[@]}"; do
        echo "  - $action"
      done
    fi
    ;;
  check)
    echo "OpenSpec repo bootstrap check for $target_root:"
    if [ "${#actions[@]}" -eq 0 ]; then
      if path_exists "$validator_path"; then
        run_validation
      fi
      echo "  - no drift detected"
      exit 0
    fi
    for action in "${actions[@]}"; do
      echo "  - drift: $action"
    done
    exit 1
    ;;
  apply)
    run_validation
    echo "OpenSpec repo bootstrap applied for $target_root:"
    if [ "${#actions[@]}" -eq 0 ]; then
      echo "  - no changes needed"
    else
      for action in "${actions[@]}"; do
        echo "  - $action"
      done
    fi
    ;;
esac
